<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<VBox maxHeight="Infinity" maxWidth="Infinity" spacing="14.0" styleClass="page-root" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tool.send_email.javafx.controller.GuiActivityController">
   <children>
      <VBox spacing="12.0" styleClass="section-card">
         <children>
            <Label styleClass="section-title" text="发送统计与记录" />
            <Label styleClass="section-hint" text="每次发送任务结束后写入本地日志（系统临时目录 send-email-app/activity）。可用于审计与复盘。" />
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#refresh" styleClass="btn-primary" text="刷新" />
               </children>
            </HBox>
            <Label styleClass="form-label" text="汇总" />
            <TextArea fx:id="statsArea" editable="false" prefRowCount="8" wrapText="true" />
            <Label styleClass="form-label" text="最近记录（新→旧）" />
            <TextArea fx:id="recordsArea" editable="false" prefRowCount="16" styleClass="log-area" wrapText="true" />
         </children>
         <padding>
            <Insets bottom="18.0" left="18.0" right="18.0" top="16.0" />
         </padding>
      </VBox>
   </children>
</VBox>
