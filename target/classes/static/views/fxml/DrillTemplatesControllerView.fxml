<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<VBox maxHeight="Infinity" maxWidth="Infinity" spacing="14.0" styleClass="page-root" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tool.send_email.javafx.controller.GuiDrillTemplatesController">
   <children>
      <VBox spacing="12.0" styleClass="section-card">
         <children>
            <Label styleClass="section-title" text="安全意识演练模板" />
            <Label styleClass="section-hint" text="仅限经授权的安全演练。正文含「授权演练」横幅；部署后路径可填到「模板邮件」的模板文件字段。" />
            <HBox spacing="14.0" VBox.vgrow="ALWAYS">
               <children>
                  <ListView fx:id="templateList" prefHeight="260.0" prefWidth="260.0" />
                  <TextArea fx:id="detailArea" editable="false" prefHeight="260.0" wrapText="true" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#deploySelected" styleClass="btn-primary" text="部署到本机" />
                  <Button mnemonicParsing="false" onAction="#copyPath" styleClass="btn-secondary" text="复制路径" />
               </children>
            </HBox>
            <Label fx:id="pathLabel" styleClass="section-hint" wrapText="true" />
         </children>
         <padding>
            <Insets bottom="18.0" left="18.0" right="18.0" top="16.0" />
         </padding>
      </VBox>
   </children>
</VBox>
